{
  "version": 2,
  "buildCommand": "echo 'Deploying prebuilt Flutter web output'",
  "outputDirectory": "frontend-mobile/build/web",
  "rewrites": [
    {
      "source": "^/(.*)$",
      "destination": "/index.html"
    }
  ],
  "experimentalServices": {
    "frontend": {
      "entrypoint": "frontend-mobile/build/web/index.html",
      "framework": "static",
      "routePrefix": "/"
    }
  }
}
