FLASK_ENV=development
FLASK_APP=run.py
MONGODB_URI=mongodb://localhost:27017/foodhub
CORS_ORIGINS=http://localhost:3000,http://localhost:5000,http://127.0.0.1:3000,http://127.0.0.1:5000
SECRET_KEY=foodhub-secret-key-development
JWT_SECRET_KEY=foodhub-jwt-secret-key-development
DEBUG=True

# AWS SMS Configuration (for SMS notifications on card generation)
# Get these from AWS IAM: https://console.aws.amazon.com/iam/
# Instructions: https://docs.aws.amazon.com/general/latest/gr/aws-sec-cred-types.html
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SNS_REGION=us-east-1
AWS_SNS_PHONE_REGION=+91
ENABLE_SMS_NOTIFICATIONS=false
