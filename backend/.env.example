# FoodHub Backend - Environment Configuration

# Flask Environment (development, testing, production)
FLASK_ENV=development
FLASK_APP=run.py

# MongoDB Configuration
# For local development: mongodb://localhost:27017/fooddelivery
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/fooddelivery?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/fooddelivery

# JWT Security - Change these in production!
SECRET_KEY=your-secret-key-here-change-in-production
JWT_SECRET_KEY=your-jwt-secret-key-here-change-in-production

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001

# AWS SNS Configuration (for SMS notifications)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_SNS_REGION=us-east-1
AWS_SNS_PHONE_REGION=+91

# SMS Notifications
ENABLE_SMS_NOTIFICATIONS=false

# Logging
LOG_DIR=logs
LOG_LEVEL=INFO

# Rate Limiting
RATELIMIT_ENABLED=true

# Server Configuration
HOST=0.0.0.0
PORT=5000
DEBUG=true

# Database Configuration
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# Email Configuration (optional)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-email-password

# Redis Configuration (optional, for caching/sessions)
REDIS_URL=redis://localhost:6379/0
