# FoodHub Backend - Environment Configuration Template
# IMPORTANT: Copy this to .env and fill in your actual values
# NEVER commit .env with real credentials to version control!

# Flask Environment (development, testing, production)
FLASK_ENV=production
FLASK_APP=run.py

# MongoDB Configuration
# MongoDB Atlas Connection - Get from your MongoDB Atlas cluster
MONGODB_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/fooddelivery?retryWrites=true&w=majority

# JWT Security - Generate secure random strings for production
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=CHANGE_THIS_IN_PRODUCTION_USE_STRONG_RANDOM_KEY
JWT_SECRET_KEY=CHANGE_THIS_IN_PRODUCTION_USE_STRONG_RANDOM_KEY

# CORS Configuration - Update with your deployed frontend URLs
CORS_ORIGINS=https://yourdomain.vercel.app,http://localhost:3000,http://127.0.0.1:3000

# AWS SNS Configuration (for SMS notifications) - OPTIONAL
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_SNS_REGION=us-east-1
AWS_SNS_PHONE_REGION=+91

# SMS Notifications
ENABLE_SMS_NOTIFICATIONS=false

# Logging
LOG_DIR=logs
LOG_LEVEL=INFO

# Rate Limiting
RATELIMIT_ENABLED=true

# Server Configuration
HOST=0.0.0.0
PORT=5000
DEBUG=false

# Database Configuration
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# Email Configuration (optional)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-email-password

# Redis Configuration (optional, for caching/sessions)
REDIS_URL=redis://localhost:6379/0
