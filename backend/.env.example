# Flask Configuration
FLASK_ENV=production
FLASK_APP=run.py
SECRET_KEY=your-secret-key-here-change-in-production

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/bankmanagement

# JWT Configuration
JWT_SECRET_KEY=your-jwt-secret-key-here-change-in-production
JWT_ACCESS_TOKEN_EXPIRES=3600
JWT_REFRESH_TOKEN_EXPIRES=604800

# CORS - Configure based on frontend deployment
# LOCAL DEVELOPMENT:
#   http://localhost:3000,http://127.0.0.1:3000
#
# VERCEL DEPLOYMENT:
#   https://your-frontend.vercel.app
#
# BOTH (Recommended during testing):
#   http://localhost:3000,https://your-frontend.vercel.app,https://your-replit.replit.dev
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Bcrypt
BCRYPT_LOG_ROUNDS=12

# Logging
LOG_DIR=./logs

# Environment
DEBUG=False
